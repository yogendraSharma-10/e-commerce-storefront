# General Application Settings
NODE_ENV=development
PORT=5000

# Database Configuration (MongoDB)
# Example: MONGO_URI=mongodb://localhost:27017/ecommerce_db
# For production, use a secure connection string with authentication.
MONGO_URI=mongodb://localhost:27017/ecommerce_storefront_db

# JWT Authentication
JWT_SECRET=supersecretjwtkeythatshouldbeverylongandrandom
JWT_EXPIRES_IN=1h # e.g., 1h, 24h, 7d

# Client-side Configuration (for React app)
# This variable will be exposed to the client-side bundle if prefixed with REACT_APP_
REACT_APP_API_BASE_URL=http://localhost:5000/api/v1

# Payment Gateway (Stripe Example)
# Get your keys from the Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Cloudinary for Image Uploads (e.g., product images, user avatars)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service Configuration (e.g., Nodemailer with SendGrid, Mailgun, or SMTP)
EMAIL_SERVICE_HOST=smtp.mailtrap.io # Example for development
EMAIL_SERVICE_PORT=2525
EMAIL_SERVICE_USER=your_email_service_username
EMAIL_SERVICE_PASS=your_email_service_password
EMAIL_FROM=noreply@yourdomain.com

# Python Inventory Sync Service Configuration
# This key can be used by the Python service to authenticate with the Node.js backend API
INVENTORY_SYNC_API_KEY=securekeyforinventorysyncservice
# If the Python service syncs with an external inventory provider
INVENTORY_PROVIDER_API_URL=https://api.externalinventory.com/v1
INVENTORY_PROVIDER_API_KEY=external_inventory_provider_api_key
# How often the inventory sync service should run (in seconds)
INVENTORY_SYNC_INTERVAL_SECONDS=3600 # Every hour

# Cross-Project Microservice Integrations
# AI-Powered Content Summarizer Service
# Used for generating product descriptions, summarizing user reviews, etc.
AI_SUMMARIZER_API_URL=http://localhost:6001/api/v1/summarize
AI_SUMMARIZER_API_KEY=ai_summarizer_service_api_key

# Full-Stack Blog Platform Service
# Used for fetching related blog posts, news, or articles for products/categories.
BLOG_PLATFORM_API_URL=http://localhost:7001/api/v1/posts
BLOG_PLATFORM_API_KEY=blog_platform_service_api_key

# Collaborative Code Editor Service
# Potentially used for collaborative editing of product descriptions or marketing content in the admin panel.
COLLABORATIVE_EDITOR_API_URL=http://localhost:8001/api/v1/documents
COLLABORATIVE_EDITOR_API_KEY=collaborative_editor_service_api_key

# Recipe & Meal Planner Service
# If the e-commerce platform sells food-related products, this could be used for recipe suggestions.
RECIPE_PLANNER_API_URL=http://localhost:9001/api/v1/recipes
RECIPE_PLANNER_API_KEY=recipe_planner_service_api_key

# Admin User Credentials (for initial setup or development)
# In production, these should be managed securely, e.g., through an admin registration process.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword123